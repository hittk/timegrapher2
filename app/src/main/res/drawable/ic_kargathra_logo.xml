<?xml version="1.0" encoding="utf-8"?>
<!--
    KARGATHRA & Co. logo.
    Inverted triangle (outline) containing a serif capital K (filled).

    Viewport: 108x108 (matches Android adaptive-icon canvas so the same
    drawable can be reused between the in-app header and launcher icon).

    Safe zone: centre 72x72dp of the 108x108 canvas — the triangle is
    drawn fully inside this zone so the launcher-icon mask never clips
    the logo.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Inverted (downward-pointing) triangle outline.
        Top-left (22, 28) → top-right (86, 28) → bottom point (54, 82).
        Drawn as a filled hollow shape (outer triangle minus inner triangle)
        to give a uniform stroke that scales cleanly.
    -->
    <path
        android:pathData="M 22,28 L 86,28 L 54,82 Z
                          M 27,31 L 81,31 L 54,77 Z"
        android:fillColor="@color/gold_primary"
        android:fillType="evenOdd" />

    <!--
        Serif capital K, centred inside the triangle.
        Composed as two filled subpaths:
          1. Vertical stroke (left) with top and bottom serifs
          2. Diagonal strokes (upper and lower) meeting at the middle,
             also with serifs at the open ends

        Glyph box roughly (44, 38) to (66, 66).
    -->
    <path
        android:pathData="
            M 43,38 L 51,38 L 51,41 L 49,41 L 49,63 L 51,63 L 51,66 L 43,66 L 43,63 L 45,63 L 45,41 L 43,41 Z
            M 54,38 L 63,38 L 63,41 L 61,41 L 54,49 L 62,63 L 64,63 L 64,66 L 55,66 L 55,63 L 57,63 L 51,53 L 49,55 L 49,50 L 56,43 L 54,41 Z"
        android:fillColor="@color/gold_primary"
        android:fillType="nonZero" />

</vector>
